@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SD_Quiz</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SD_Quiz.styles.css" asp-append-version="true" />

    <style>
            .navbar-custom {
                background-color: #ffffff !important;
                box-shadow: 0 4px 20px rgba(118, 75, 162, 0.03) !important;
                border-bottom: 1px solid #f1f5f9 !important;
            }

            /* Sağ Üst Profil Çipi */
            .profile-chip {
                background: #f8fafc;
                border: 1px solid #e2e8f0;
                padding: 0.45rem 1.1rem;
                border-radius: 50px;
                font-weight: 600;
                color: #4a5568 !important;
                transition: all 0.2s ease;
            }

                .profile-chip:hover, .profile-chip:focus {
                    background: #f1f5f9;
                    border-color: #cbd5e1;
                    transform: translateY(-1px);
                }

            .dropdown-item {
                font-weight: 500;
                color: #4a5568;
                transition: all 0.2s ease;
            }

                .dropdown-item:hover {
                    background-color: #f8fafc;
                    color: #764ba2;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light navbar-custom mb-4 py-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;" asp-area="" asp-controller="Home" asp-action="Index">SD_Quiz 🧠</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Home" asp-action="Index">🏠 Ana Sayfa</a>
                        </li>
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Quiz" asp-action="Create">✨ Quiz Oluştur</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (Context.Session.GetString("IsAdmin") == "True")
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Index">🛡️ Admin Paneli</a>
                            </li>
                        }
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle profile-chip d-flex align-items-center gap-1" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    👑 @Context.Session.GetString("Username")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 p-2 mt-2" aria-labelledby="profileDropdown">
                                    <li>
                                        <a class="dropdown-item rounded-3 py-2" asp-controller="Home" asp-action="MyProfile">👤 Profilim</a>
                                    </li>
                                    <li><hr class="dropdown-divider opacity-50"></li>
                                    <li>
                                        <a class="dropdown-item text-danger rounded-3 py-2" asp-controller="Account" asp-action="Logout">🚪 Çıkış Yap</a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center py-3 mt-5 w-100">
        <div class="container">
            &copy; 2026 - SD_Quiz - Tüm Hakları Saklıdır.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>