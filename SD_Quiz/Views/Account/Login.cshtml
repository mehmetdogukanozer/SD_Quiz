@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h3>SD_Quiz - Giriş Yap</h3>
            </div>
            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="form-group mb-3">
                        <label class="form-label">Kullanıcı Adı</label>
                        <input name="username" class="form-control" placeholder="Kullanıcı adınız" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Şifre</label>
                        <input name="password" type="password" class="form-control" placeholder="Şifreniz" required />
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Giriş Yap</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center">
                <a asp-action="Register" class="text-decoration-none">Hesabın yok mu? Yeni Hesap Aç</a>
            </div>
        </div>
    </div>
</div>