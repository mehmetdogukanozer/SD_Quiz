@model List<SD_Quiz.Models.Category>

@{
    ViewData["Title"] = "Ana Sayfa - Dashboard";
}

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold text-primary">Hoş geldin, @ViewBag.Username!</h1>
            <p class="col-md-8 fs-4 text-muted">Bugünkü yarışma haklarını kullanmak ve liderlik tablosunda yükselmek için bir kategori seç.</p>

            <div class="d-flex gap-3 mt-3">
                <span class="badge bg-dark fs-5 p-2">🏆 Toplam Puan: @ViewBag.TotalPoints</span>
                <span class="badge bg-warning text-dark fs-5 p-2">⭐ Rütbe: @ViewBag.Rank</span>
            </div>
        </div>
    </div>

    <h2 class="mb-4 border-bottom pb-2">Oyun Kategorileri</h2>

    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center fs-5">
                    📌 Şu anda veritabanında aktif kategori bulunmamaktadır. (Admin paneli veya seeding bekleniyor).
                </div>
            </div>
        }
        else
        {
            @foreach (var category in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm border-primary">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h4 class="card-title fw-bold text-dark">@category.Name</h4>
                                <p class="card-text text-muted">Bu kategorideki resimli soruları çözerek puanları topla. Dikkat et, günde sadece 1 kez oynama hakkın var!</p>
                            </div>
                            <div class="d-grid mt-4">
                                <a href="/Quiz/Start?categoryId=@category.Id" class="btn btn-primary btn-lg fw-bold">Yarışmayı Başlat 🚀</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>