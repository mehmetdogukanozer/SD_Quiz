@model List<SD_Quiz.Controllers.CategoryRatingViewModel>
@{
    ViewData["Title"] = "Ana Sayfa - Dashboard";
    var leaderboardToday = ViewBag.LeaderboardToday as List<SD_Quiz.Controllers.LeaderboardViewModel>;
    var leaderboardWeekly = ViewBag.LeaderboardWeekly as List<SD_Quiz.Controllers.LeaderboardViewModel>;
}

<style>
    :root {
        --auth-purple: #764ba2;
        --auth-indigo: #667eea;
        --auth-emerald: #11998e;
        --auth-mint: #38ef7d;
        --card-shadow: 0 10px 30px rgba(118, 75, 162, 0.05);
        --hover-shadow: 0 15px 35px rgba(118, 75, 162, 0.12);
    }

    /* Üst Karşılama Banner Alanı (Giriş Ekranı Mor/İndigo Tonları) */
    .hero-banner {
        background: linear-gradient(135deg, var(--auth-indigo) 0%, var(--auth-purple) 100%);
        border-radius: 20px;
        padding: 3rem 2.5rem;
        color: white;
        box-shadow: 0 15px 30px rgba(118, 75, 162, 0.2);
        position: relative;
        overflow: hidden;
    }

        .hero-banner::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
            pointer-events: none;
        }

    /* Profil Rozetleri (Puan ve Rütbe) */
    .badge-custom {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255, 255, 255, 0.25);
        color: white;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        transition: all 0.3s ease;
    }

        .badge-custom:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: translateY(-2px);
        }

    /* Sol Kenar Çizgili Bölüm Başlıkları */
    .section-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #2d3748;
        position: relative;
        padding-left: 12px;
    }

        .section-title::before {
            content: '';
            position: absolute;
            left: 0;
            top: 4px;
            bottom: 4px;
            width: 4px;
            background: var(--auth-purple);
            border-radius: 4px;
        }

        .section-title.emerald::before {
            background: var(--auth-emerald);
        }

    /* Quiz Kategorileri Kart Yapısı */
    .quiz-card {
        background: #ffffff;
        border: none;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .quiz-card:hover {
            transform: translateY(-6px);
            box-shadow: var(--hover-shadow);
        }

    .rating-badge {
        background: #fffdf0;
        border: 1px solid #fef08a;
        color: #ca8a04;
        font-weight: 700;
        font-size: 0.8rem;
        padding: 0.3rem 0.7rem;
    }

    .favori-badge {
        background: #fff5f5;
        border: 1px solid #fed7d7;
        color: #e53e3e;
        font-weight: 600;
        font-size: 0.75rem;
        padding: 0.3rem 0.7rem;
    }

    /* Buton Tasarımları */
    .btn-start-quiz {
        background: #ffffff;
        border: 2px solid var(--auth-indigo);
        color: var(--auth-indigo);
        font-weight: 700;
        border-radius: 50px;
        padding: 0.6rem;
        transition: all 0.3s ease;
    }

        .btn-start-quiz:hover {
            background: linear-gradient(135deg, var(--auth-indigo) 0%, var(--auth-purple) 100%);
            border-color: transparent;
            color: white;
            box-shadow: 0 5px 15px rgba(118, 75, 162, 0.25);
        }

    /* Liderlik Tablosu (Leaderboard) */
    .leaderboard-box {
        background: #ffffff;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        border: none;
        overflow: hidden;
    }

    .leaderboard-header {
        color: white;
        padding: 1.1rem 1.25rem;
        font-weight: 700;
        font-size: 1.05rem;
        border: none;
    }

        .leaderboard-header.emerald {
            background: linear-gradient(135deg, var(--auth-emerald) 0%, var(--auth-mint) 100%);
        }

        .leaderboard-header.purple {
            background: linear-gradient(135deg, var(--auth-indigo) 0%, var(--auth-purple) 100%);
        }

    .leaderboard-item {
        border-bottom: 1px solid #f7fafc;
        padding: 0.9rem 1.25rem;
        transition: background 0.2s ease;
    }

        .leaderboard-item:hover {
            background: #f8fafc;
        }

    .rank-number {
        font-weight: 800;
        color: #a0aec0;
        width: 24px;
        display: inline-block;
    }

    .leaderboard-item:nth-child(1) .rank-number {
        color: #ecc94b;
    }
    /* Altın Rengi */
    .leaderboard-item:nth-child(2) .rank-number {
        color: #cbd5e0;
    }
    /* Gümüş Rengi */

    .score-pill {
        background: #f7fafc;
        color: #4a5568;
        font-weight: 700;
        font-size: 0.8rem;
        padding: 0.35rem 0.8rem;
        border-radius: 30px;
        border: 1px solid #e2e8f0;
    }

    /* YENI: Profil Linkleri Üzerine Gelince Mor Olma Efekti */
    .style-profile-link:hover {
        color: var(--auth-purple) !important;
    }
</style>

<div class="container mt-4">
    <div class="p-5 mb-4 hero-banner text-white">
        <div class="container-fluid py-1">
            <h1 class="display-5 fw-bold mb-3">Hoş geldin, @ViewBag.Username! 👋</h1>
            <p class="fs-5 opacity-75">Yarışmak için bir kategori seç, liderlik tablosunda yerini al.</p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <div class="badge-custom shadow-sm">🏆 Toplam Puan: @ViewBag.TotalPoints</div>
                <div class="badge-custom shadow-sm">⭐ Rütbe: @ViewBag.Rank</div>
            </div>
        </div>
    </div>

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning text-center rounded-3 shadow-sm mb-4">
            ⚠️ @TempData["Warning"]
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center rounded-3 shadow-sm mb-4">
            ✅ @TempData["Success"]
        </div>
    }

    <div class="row g-4">
        <div class="col-md-8">
            <h3 class="mb-4 fw-bold section-title">Oyun Kategorileri</h3>
            <div class="row g-3">
                @if (Model == null || !Model.Any())
                {
                    <div class="col-12">
                        <div class="alert alert-info text-center rounded-3">
                            📌 Şu anda aktif veya onaylanmış bir oyun kategorisi bulunmuyor.
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var category in Model)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 quiz-card p-2">
                                <div class="card-body d-flex flex-column justify-content-between">
                                    <div>
                                        <h5 class="card-title fw-bold text-dark mb-2 d-flex justify-content-between align-items-center">
                                            <span>
                                                @category.Name
                                                @if (ViewBag.FavoriteCategoryId != null && ViewBag.FavoriteCategoryId == category.Id)
                                                {
                                                    <span class="badge favori-badge ms-2 rounded-pill">❤️ Favorin</span>
                                                }
                                            </span>
                                            <span class="badge rating-badge rounded-pill shadow-sm">
                                                ★ @category.AvgRating.ToString("0.0")
                                            </span>
                                        </h5>
                                        <p class="text-muted small mt-3">Resimli soruları çöz, puanları topla! Günde 1 kez oynama hakkın var.</p>
                                    </div>
                                    <div class="d-grid mt-3">
                                        <a href="/Quiz/Start?categoryId=@category.Id" class="btn btn-start-quiz fw-bold">Yarışmayı Başlat 🚀</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-md-4">
            <div style="position: sticky; top: 20px;">
                <h3 class="mb-4 fw-bold section-title emerald">🏆 En İyiler</h3>

                <div class="card leaderboard-box mb-4">
                    <div class="card-header leaderboard-header emerald fw-bold">HN Bugünün Liderleri</div>
                    <ul class="list-group list-group-flush">
                        @if (leaderboardToday == null || !leaderboardToday.Any())
                        {
                            <li class="list-group-item text-muted text-center py-4 border-0">Henüz yarışan olmadı. İlk sen ol!</li>
                        }
                        else
                        {
                            int siraToday = 1;
                            @foreach (var user in leaderboardToday)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center leaderboard-item border-0 border-bottom">
                                    <span>
                                        <strong class="rank-number">#@siraToday</strong>
                                        <a href="/Home/UserProfile?id=@user.UserId" class="fw-bold text-dark text-decoration-none style-profile-link" style="transition: color 0.2s ease;">@user.Username</a>
                                    </span>
                                    <span class="score-pill">@user.TotalPoints Puan</span>
                                </li>
                                siraToday++;
                            }
                        }
                    </ul>
                </div>

                <div class="card leaderboard-box">
                    <div class="card-header leaderboard-header purple fw-bold">📅 Bu Hafta (Son 7 Gün)</div>
                    <ul class="list-group list-group-flush">
                        @if (leaderboardWeekly == null || !leaderboardWeekly.Any())
                        {
                            <li class="list-group-item text-muted text-center py-4 border-0">Henüz kayıtlı skor bulunmuyor.</li>
                        }
                        else
                        {
                            int siraWeekly = 1;
                            @foreach (var user in leaderboardWeekly)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center leaderboard-item border-0 border-bottom">
                                    <span>
                                        <strong class="rank-number">#@siraWeekly</strong>
                                        <a href="/Home/UserProfile?id=@user.UserId" class="fw-bold text-dark text-decoration-none style-profile-link" style="transition: color 0.2s ease;">@user.Username</a>
                                    </span>
                                    <span class="score-pill">@user.TotalPoints Puan</span>
                                </li>
                                siraWeekly++;
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>