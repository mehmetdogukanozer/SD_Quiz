@model SD_Quiz.Models.User
@{
    ViewData["Title"] = Model.Username + " Profili";
}

<div class="container mt-4">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow border-0 text-center p-4 rounded-4">
                <div class="card-body">
                    <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle img-thumbnail mb-3 shadow" style="width: 130px; height: 130px; object-fit: cover;" />
                    <h3 class="fw-bold text-dark">@Model.Username</h3>
                    <p class="text-muted fst-italic mt-2">"@Model.Bio"</p>
                    <hr class="opacity-50" />
                    <div class="alert alert-light text-center small text-muted border-0 rounded-3">
                        📌 Bu bir kullanıcı profilidir. Sadece oyuncunun istatistikleri ve geçmiş skorları görüntülenebilir.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="row g-3 mb-4">
                <div class="col-md-4"><div class="card bg-primary text-white text-center py-3 border-0 shadow-sm rounded-4"><h4>@ViewBag.GamesPlayed</h4><span>Çözülen Quiz</span></div></div>
                <div class="col-md-4"><div class="card bg-success text-white text-center py-3 border-0 shadow-sm rounded-4"><h4>@ViewBag.AverageScore</h4><span>Ortalama Skor</span></div></div>
                <div class="col-md-4"><div class="card bg-warning text-dark text-center py-3 border-0 shadow-sm rounded-4"><h4>@ViewBag.HighestScore</h4><span>En Yüksek Skor</span></div></div>
            </div>

            <h4 class="mb-3 border-bottom pb-2 fw-bold text-secondary">🎮 Oyuncu Aktivite Geçmişi</h4>
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Tarih</th>
                            <th>Kategori</th>
                            <th class="text-end">Puan</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Scores == null || !Model.Scores.Any())
                        {
                            <tr><td colspan="3" class="text-center py-4 text-muted">Bu oyuncu henüz bir yarışmaya katılmadı.</td></tr>
                        }
                        else
                        {
                            @foreach (var score in Model.Scores)
                            {
                                <tr>
                                    <td>@score.DatePlayed.ToString("dd.MM.yyyy")</td>
                                    <td class="fw-bold text-dark">@score.Category?.Name</td>
                                    <td class="text-end"><span class="badge bg-success fs-6 rounded-pill px-3">@score.PointsEarned Puan</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>